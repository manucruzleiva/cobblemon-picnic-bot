# TEMPLATE — copy to .env and fill that in. This file is COMMITTED, so it must stay empty.
# Put real secrets ONLY in .env (gitignored). Never paste tokens here.

# Discord BOT TOKEN (a secret like "MTxxxxxxxxxxxx.xxxxxx.xxxxxxxxxxxxxxxxxxxxxxx").
# Developer Portal -> your app -> Bot -> Reset Token.  This is NOT the invite/OAuth URL.
DISCORD_TOKEN=

# GitHub token that can open issues on the repo below.
# Fine-grained PAT (github.com/settings/tokens?type=beta):
#   Repository access = manucruzleiva/cobblemon-picnic, Permissions -> Issues: Read and write.
GITHUB_TOKEN=

# Target repository for issues (owner/name)
GITHUB_REPO=manucruzleiva/cobblemon-picnic

# Optional: your Discord server (guild) ID for instant slash-command registration.
GUILD_ID=
